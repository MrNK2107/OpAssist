{
  "manifest_version": 3,
  "name": "OpAssist - Opportunity Saver",
  "version": "1.0.0",
  "description": "Save hackathons, internships, and opportunities from the web to your OpAssist dashboard.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://devfolio.co/*", "https://unstop.com/*", "https://www.hackerearth.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "OpAssist"
  },
  "content_scripts": [
    {
      "matches": [
        "https://devfolio.co/*",
        "https://unstop.com/*",
        "https://www.hackerearth.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
